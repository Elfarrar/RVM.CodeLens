@page "/"
@using RVM.CodeLens.Core.Services
@inject IAnalysisStateService StateService
@inject ISolutionAnalyzer Analyzer
@inject IGitCloneService CloneService
@inject NavigationManager Navigation

<h1>RVM.CodeLens</h1>
<p class="subtitle">Analyze your .NET solution</p>

<div class="analyze-form">
    <div class="source-toggle">
        <button class="toggle-btn @(UseUrl ? "" : "active")" @onclick="() => UseUrl = false">Local Path</button>
        <button class="toggle-btn @(UseUrl ? "active" : "")" @onclick="() => UseUrl = true">Git Repository</button>
    </div>

    @if (UseUrl)
    {
        <label for="repoUrl">Public Git repository URL:</label>
        <div class="input-group">
            <input id="repoUrl" type="text" @bind="RepositoryUrl"
                   placeholder="https://github.com/user/repo.git" class="input-path" />
            <button class="btn-analyze" @onclick="AnalyzeFromUrlAsync" disabled="@IsAnalyzing">
                @(IsAnalyzing ? StatusMessage : "Clone & Analyze")
            </button>
        </div>
    }
    else
    {
        <label for="solutionPath">Solution path (.sln or .slnx):</label>
        <div class="input-group">
            <input id="solutionPath" type="text" @bind="SolutionPath"
                   placeholder="C:\path\to\solution.slnx" class="input-path" />
            <button class="btn-analyze" @onclick="AnalyzeLocalAsync" disabled="@IsAnalyzing">
                @(IsAnalyzing ? "Analyzing..." : "Analyze")
            </button>
        </div>
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <p class="error">@ErrorMessage</p>
    }
</div>

@if (StateService.GetCurrentAnalysis() is { } current)
{
    <div class="current-analysis">
        <h3>Current Analysis</h3>
        <p><strong>@current.SolutionName</strong> — @current.Projects.Count projects, @current.Projects.Sum(p => p.Metrics.CodeLines).ToString("N0") LOC</p>
        <p class="dim">Analyzed at @current.AnalyzedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</p>
        <a href="/dashboard" class="btn-go">Go to Dashboard →</a>
    </div>
}

@code {
    private string SolutionPath { get; set; } = "";
    private string RepositoryUrl { get; set; } = "";
    private bool UseUrl { get; set; }
    private bool IsAnalyzing { get; set; }
    private string StatusMessage { get; set; } = "Analyzing...";
    private string? ErrorMessage { get; set; }

    private async Task AnalyzeLocalAsync()
    {
        if (string.IsNullOrWhiteSpace(SolutionPath)) return;

        IsAnalyzing = true;
        ErrorMessage = null;
        StateHasChanged();

        try
        {
            var result = await Analyzer.AnalyzeAsync(Path.GetFullPath(SolutionPath));
            StateService.SetCurrentAnalysis(result);
            Navigation.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsAnalyzing = false;
        }
    }

    private async Task AnalyzeFromUrlAsync()
    {
        if (string.IsNullOrWhiteSpace(RepositoryUrl)) return;

        IsAnalyzing = true;
        ErrorMessage = null;
        StatusMessage = "Cloning...";
        StateHasChanged();

        string? clonePath = null;
        try
        {
            var cloneResult = await CloneService.CloneAndDiscoverAsync(RepositoryUrl);
            clonePath = cloneResult.ClonePath;

            StatusMessage = "Analyzing...";
            StateHasChanged();

            var result = await Analyzer.AnalyzeAsync(cloneResult.SolutionPath);
            StateService.SetCurrentAnalysis(result);
            Navigation.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            if (clonePath is not null)
                CloneService.Cleanup(clonePath);

            IsAnalyzing = false;
            StatusMessage = "Analyzing...";
        }
    }
}
